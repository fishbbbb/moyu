{
  "name": "desktop",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node ./scripts/ensure-dist-electron.mjs && tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on http://127.0.0.1:5173 && node ./scripts/ensure-electron.mjs && node ./scripts/ensure-dist-electron.mjs && node ./scripts/electron-dev.mjs .\"",
    "build": "node ./scripts/ensure-dist-electron.mjs && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "lint": "echo \"(optional) add eslint later\"",
    "selftest:chapters": "node ./scripts/selftest-chapter-split.mjs",
    "rebuild:native": "cross-env PYTHONPATH=./scripts/py-distutils electron-rebuild -f -w better-sqlite3",
    "postinstall": "node ./scripts/ensure-electron.mjs && npm run rebuild:native"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^12.6.2",
    "fast-xml-parser": "^5.3.0",
    "jsdom": "^24.0.0",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
